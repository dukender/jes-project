        // ===== ระบบ Dashboard กราฟสถิติ =====
        function getWeekNumber(d) {
            d = new Date(Date.UTC(d.getFullYear(), d.getMonth(), d.getDate()));
            d.setUTCDate(d.getUTCDate() + 4 - (d.getUTCDay()||7));
            var yearStart = new Date(Date.UTC(d.getUTCFullYear(),0,1));
            var weekNo = Math.ceil(( ( (d - yearStart) / 86400000) + 1)/7);
            return weekNo;
        }

        function renderDashboard() {
            if (allTasks.length === 0) return; // ไม่มีข้อมูลไม่วาดกราฟ
            
            // เตรียมข้อมูล Month / Week
            const timeData = { months: {}, weeks: {} };
            // เตรียมข้อมูลสัดส่วน
            const counts = { responsible: {}, customer: {}, assignment: {} };

            allTasks.forEach(t => {
                if (!t.receiveDate) return;
                const d = new Date(t.receiveDate);
                
                // นับรายเดือน (YYYY-MM)
                const monthKey = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2, '0')}`;
                timeData.months[monthKey] = (timeData.months[monthKey] || 0) + 1;
                
                // นับรายสัปดาห์ (WXX YYYY)
                const weekKey = `W${getWeekNumber(d)} ${d.getFullYear()}`;
                timeData.weeks[weekKey] = (timeData.weeks[weekKey] || 0) + 1;

                // นับสัดส่วน
                const resp = t.responsibleName || 'ไม่ระบุ';
                counts.responsible[resp] = (counts.responsible[resp] || 0) + 1;
                
                const cust = t.customerName || 'ไม่ระบุ';
                counts.customer[cust] = (counts.customer[cust] || 0) + 1;
                
                const assign = t.assignment || 'ไม่ระบุ';
                counts.assignment[assign] = (counts.assignment[assign] || 0) + 1;
            });

            // ฟังก์ชันช่วยทำลายกราฟเก่าก่อนวาดใหม่
            const destroyChart = (chartId) => {
                if (chartInstances[chartId]) {
                    chartInstances[chartId].destroy();
                }
            };

            // สีโทน MS Teams / Planner
            const colors = ['#5b5fc7', '#8f95d8', '#cdd0f0', '#00a4ef', '#7fba00', '#ffb900', '#f25022', '#737373'];

            // 1. กราฟเวลา (เอาแค่ 6 เดือนล่าสุด และ 6 สัปดาห์ล่าสุด)
            const timeCanvas = document.getElementById('chart-time');
            if (timeCanvas) {
                destroyChart('time');
                const sortedMonths = Object.keys(timeData.months).sort().slice(-6);
                const ctxTime = timeCanvas.getContext('2d');
                chartInstances['time'] = new Chart(ctxTime, {
                    type: 'bar',
                    data: {
                        labels: sortedMonths,
                        datasets: [{
                            label: 'จำนวนงาน (รายเดือน)',
                            data: sortedMonths.map(k => timeData.months[k]),
                            backgroundColor: '#5b5fc7',
                            borderRadius: 4
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: false }
                });
            }

            // ฟังก์ชันช่วยวาด Pie/Doughnut Chart
            const drawPieChart = (canvasId, dataObj, titleStr) => {
                const canvas = document.getElementById(`chart-${canvasId}`);
                if (!canvas) return;
                destroyChart(canvasId);
                const sortedKeys = Object.keys(dataObj).sort((a, b) => dataObj[b] - dataObj[a]).slice(0, 5); // เอา Top 5
                const ctx = canvas.getContext('2d');
                chartInstances[canvasId] = new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: sortedKeys,
                        datasets: [{
                            data: sortedKeys.map(k => dataObj[k]),
                            backgroundColor: colors,
                            borderWidth: 1
                        }]
                    },
                    options: { 
                        responsive: true, 
                        maintainAspectRatio: false,
                        plugins: { legend: { position: 'right' } }
                    }
                });
            };

            // 2. กราฟผู้รับผิดชอบ
            drawPieChart('responsible', counts.responsible, 'ผู้รับผิดชอบ');
            // 3. กราฟลูกค้า
            drawPieChart('customer', counts.customer, 'ลูกค้า');
            // 4. กราฟการมอบหมาย
            drawPieChart('assignment', counts.assignment, 'การมอบหมาย');
        }

        // ===== ระบบค้นหาและตัวกรอง =====
        function filterAndRenderTasks() {
            const searchInput = document.getElementById('search-input');
            const searchDateInput = document.getElementById('search-date');
            if (!searchInput || !searchDateInput) return;

            const searchText = searchInput.value.toLowerCase();
            const searchDate = searchDateInput.value;

            filteredTasks = allTasks.filter(task => {
                // กรองตามวันที่ (ถ้ามีการเลือก)
                const matchDate = searchDate ? task.receiveDate === searchDate : true;
                
                // กรองตามข้อความ โดยนำฟิลด์หลักมารวมกันเป็น String ยาวๆ เพื่อค้นหาทีเดียว
                const searchString = [
                    task.taskName, task.responsibleName, task.customerName, 
                    task.customerPhone, task.workLocation, task.assignment
                ].join(' ').toLowerCase();
                
                // เช็คกับรายละเอียดงานใน Notes ด้วย (ถ้ามี)
                const notesString = (task.notes || []).map(n => n.text).join(' ').toLowerCase();
                const fullSearchString = `${searchString} ${notesString}`;

                const matchText = searchText ? fullSearchString.includes(searchText) : true;
                
                return matchDate && matchText;
            });

            renderTasks(filteredTasks);
        }

