        // ฟังก์ชันดึงข้อมูลมาแก้ไข
        window.editTask = (taskId) => {
            const task = allTasks.find(t => t.id === taskId);
            if(!task) return;

            closeModal(); // ปิด Modal ปฏิทินก่อน (ถ้าเปิดอยู่)

            // ใส่ข้อมูลลงฟอร์ม
            const fields = ['taskName', 'receiveDate', 'responsibleName', 'assignment', 'customerName', 'customerPhone', 'workLocation'];
            fields.forEach(field => {
                const el = document.getElementById(field);
                if (el) el.value = task[field] || '';
            });
            
            // นำเข้าข้อมูล Checklist (รองรับข้อมูลเก่าที่เป็น String ให้กลายเป็น Checklist อัตโนมัติ)
            if (task.notes && Array.isArray(task.notes)) {
                currentNotes = JSON.parse(JSON.stringify(task.notes)); // Deep copy
            } else if (task.details) {
                currentNotes = [{ id: Date.now(), text: task.details, completed: false, completedAt: null }];
            } else {
                currentNotes = [];
            }
            
            // เตรียมบรรทัดว่าง 1 บรรทัดเสมอเมื่อเข้าสู่โหมดแก้ไข
            const lastNote = currentNotes[currentNotes.length - 1];
            if (!lastNote || lastNote.text.trim() !== '' || lastNote.completed) {
                currentNotes.push({ id: Date.now() + Math.random(), text: '', completed: false, completedAt: null });
            }
            renderNotes();

            currentEditTaskId = taskId;
            
            // เปลี่ยนหน้าตาปุ่มและหัวข้อฟอร์มเพื่อบอกว่ากำลังแก้ไข
            const submitBtn = document.getElementById('submit-btn');
            if (submitBtn) {
                submitBtn.innerHTML = `<i data-lucide="save" class="w-4 h-4"></i> บันทึกการแก้ไข`;
                submitBtn.className = "bg-amber-600 hover:bg-amber-700 text-white font-medium py-2 px-6 rounded-md transition-colors flex items-center gap-2 shadow-sm w-full md:w-auto justify-center";
            }
            
            const formTitle = document.querySelector('#view-manage .text-\\[\\#5b5fc7\\] span');
            if(formTitle) formTitle.textContent = `กำลังแก้ไข: ${task.taskName}`;

            // สลับไปหน้าจัดการและเลื่อนหน้าจอขึ้นไปบนสุด
            switchTab('manage'); // แก้ไข: เรียกใช้ฟังก์ชันสลับหน้าโดยตรง แทนการจำลองคลิก
            window.scrollTo({ top: 0, behavior: 'smooth' });
            
            lucide.createIcons();
        }

        // ปิด Modal เมื่อคลิกพื้นที่ว่างรอบๆ Modal
        document.getElementById('day-modal')?.addEventListener('click', (e) => {
            if (e.target === document.getElementById('day-modal')) {
                closeModal();
            }
        });

        // ===== ระบบจัดการ Checklist บันทึกย่อ =====
        window.renderNotes = () => {
            const container = document.getElementById('notes-list');
            if (!container) return;

            container.innerHTML = '';
            
            currentNotes.forEach((note) => {
                const div = document.createElement('div');
                div.className = "flex items-start gap-3 group relative";
                div.innerHTML = `
                    <div class="mt-1">
                        <input type="checkbox" class="w-4 h-4 cursor-pointer rounded border-gray-300 accent-[#5b5fc7]" 
                            ${note.completed ? 'checked' : ''} onchange="toggleNote(${note.id})">
                    </div>
                    <div class="flex-1 flex flex-col min-w-0">
                        <textarea id="note-input-${note.id}"
                            class="w-full bg-transparent border-0 border-b border-dashed border-gray-300 focus:border-[#5b5fc7] focus:ring-0 px-0 py-1 text-sm transition-colors resize-none overflow-hidden ${!note.completed ? 'text-gray-400 cursor-not-allowed opacity-60' : 'text-gray-800'}"
                            rows="1"
                            oninput="this.style.height = 'auto'; this.style.height = this.scrollHeight + 'px'; updateNoteText(${note.id}, this.value)"
                            placeholder="${!note.completed ? 'คลิก Checkbox เพื่อเปิดช่องพิมพ์รายละเอียด...' : 'เพิ่มรายละเอียด...'}"
                            ${!note.completed ? 'disabled' : ''}
                        >${note.text}</textarea>
                        ${note.completed && note.completedAt ? `<span class="text-[10px] text-[#5b5fc7] mt-1 flex items-center gap-1"><i data-lucide="clock" class="w-3 h-3"></i> เปิดเมื่อ: ${note.completedAt}</span>` : ''}
                    </div>
                    <button type="button" class="text-gray-300 hover:text-red-500 opacity-0 group-hover:opacity-100 transition-opacity p-1.5 rounded-md hover:bg-red-50 shrink-0" onclick="removeNote(${note.id})" title="ลบรายการนี้">
                        <i data-lucide="trash-2" class="w-4 h-4"></i>
                    </button>
                `;
                container.appendChild(div);
                
                // ปรับความสูงของ textarea อัตโนมัติหลังสร้าง Element เสร็จ
                if(note.text) {
                    setTimeout(() => {
                        const el = document.getElementById(`note-input-${note.id}`);
                        if(el) {
                            el.style.height = 'auto';
                            el.style.height = el.scrollHeight + 'px';
                        }
                    }, 0);
                }
            });
            lucide.createIcons();
        };

        window.toggleNote = (id) => {
            const note = currentNotes.find(n => n.id === id);
            if (note) {
                note.completed = !note.completed;
                if (note.completed) {
                    const now = new Date();
                    // ประทับเวลาเมื่อติ๊กถูกเพื่อเปิดช่องพิมพ์
                    note.completedAt = `${now.toLocaleDateString('th-TH')} ${now.toLocaleTimeString('th-TH', {hour: '2-digit', minute:'2-digit'})} น.`;
                    
                    // สร้างบรรทัดใหม่เผื่อไว้หากบรรทัดสุดท้ายถูกเปิดใช้งานไปแล้ว
                    const lastNote = currentNotes[currentNotes.length - 1];
                    if (lastNote.completed) {
                        currentNotes.push({ id: Date.now() + Math.random(), text: '', completed: false, completedAt: null });
                    }
                } else {
                    note.completedAt = null; // ล้างเวลาออกถ้าติ๊กออก (เพื่อปิดช่อง)
                }
                renderNotes();

                // โฟกัสช่องพิมพ์อัตโนมัติเมื่อกด Checkbox เปิด
                if(note.completed) {
                    setTimeout(() => {
                        const input = document.getElementById(`note-input-${note.id}`);
                        if(input) input.focus();
                    }, 10);
                }
            }
        };

        window.updateNoteText = (id, value) => {
            const note = currentNotes.find(n => n.id === id);
            if (note) note.text = value;
        };

        window.removeNote = (id) => {
            const index = currentNotes.findIndex(n => n.id === id);
            if (index === -1) return;
            
            const noteToDelete = currentNotes[index];
            currentNotes.splice(index, 1);
            
            // ถ้าลบจนหมด ให้เพิ่มช่องว่างไว้ 1 ช่องเสมอ
            if (currentNotes.length === 0) {
                currentNotes.push({ id: Date.now(), text: '', completed: false, completedAt: null });
            }
            renderNotes();

            // แจ้งเตือน undo เฉพาะรายการที่เคยติ๊กเปิด หรือพิมพ์ข้อมูลเอาไว้แล้วเท่านั้น
            if (noteToDelete.text.trim() !== '' || noteToDelete.completed) {
                showNotification("ลบรายละเอียดแล้ว", "success", () => {
                    // แทรกคืนกลับตำแหน่งเดิม
                    currentNotes.splice(index, 0, noteToDelete);
                    // ถ้าช่องว่างสุดท้ายเพิ่งถูกสร้างขึ้นอัตโนมัติจากตอนที่ลบจนหมด ให้ลบทิ้ง
                    if (currentNotes.length > 1 && currentNotes[currentNotes.length - 1].text === '' && !currentNotes[currentNotes.length - 1].completed) {
                        currentNotes.pop();
                    }
                    renderNotes();
                });
            }
        };
        // ===========================================

        // เรียกค่าเริ่มต้นของแบบฟอร์มให้มีแถว Checklist ว่าง 1 แถวเสมอ
        resetFormToAddMode();

        // Render Icons ครั้งแรก
        lucide.createIcons();
    </script>
</body>
</html>
